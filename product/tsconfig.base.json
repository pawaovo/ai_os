{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ai-os/kernel-objects": ["packages/kernel/kernel-objects/src/index.ts"],
      "@ai-os/kernel-memory": ["packages/kernel/kernel-memory/src/index.ts"],
      "@ai-os/kernel-events": ["packages/kernel/kernel-events/src/index.ts"],
      "@ai-os/conversation-core": ["packages/conversation/conversation-core/src/index.ts"],
      "@ai-os/conversation-runtime": ["packages/conversation/conversation-runtime/src/index.ts"],
      "@ai-os/companion-core": ["packages/companion/companion-core/src/index.ts"],
      "@ai-os/approval-core": ["packages/control/approval-core/src/index.ts"],
      "@ai-os/control-plane": ["packages/control/control-plane/src/index.ts"],
      "@ai-os/workspace-core": ["packages/workspace/workspace-core/src/index.ts"],
      "@ai-os/artifact-core": ["packages/workspace/artifact-core/src/index.ts"],
      "@ai-os/provider-protocol": ["packages/model-providers/provider-protocol/src/index.ts"],
      "@ai-os/provider-registry": ["packages/model-providers/provider-registry/src/index.ts"],
      "@ai-os/executor-protocol": ["packages/executors/executor-protocol/src/index.ts"],
      "@ai-os/executor-codex": ["packages/executors/executor-codex/src/index.ts"],
      "@ai-os/executor-claude-code": ["packages/executors/executor-claude-code/src/index.ts"]
    }
  }
}
